{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://heimgewebe.tools/contracts/pr-delta-card.v1.schema.json",
  "title": "PR Delta Card v1",
  "description": "A PR Delta Card combines a diagnostic change observation with a navigational Lens projection for a specific repository path. It establishes no truth, risk, impact, or GitHub PR identity.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "authority",
    "canonicality",
    "delta_context",
    "path",
    "change_status",
    "primary_lens",
    "matched_rule",
    "facets",
    "navigation_refs",
    "does_not_establish"
  ],
  "properties": {
    "kind": {
      "const": "repolens.pr_delta_card"
    },
    "version": {
      "const": "1.0"
    },
    "authority": {
      "const": "navigation_index"
    },
    "canonicality": {
      "const": "derived"
    },
    "delta_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_kind", "repo", "generated_at"],
      "properties": {
        "source_kind": {
          "const": "repolens.pr_schau.delta"
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "source_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_delta_sha256"],
      "properties": {
        "source_delta_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "change_status": {
      "type": "string",
      "enum": ["added", "changed", "removed"]
    },
    "primary_lens": {
      "type": "string"
    },
    "matched_rule": {
      "type": "string",
      "minLength": 1
    },
    "facets": {
      "type": "array"
    },
    "navigation_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1
    },
    "does_not_establish": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "additionalItems": false,
      "description": "Fixed canonical negative-semantics tuple.",
      "items": [
        { "const": "truth" },
        { "const": "correctness" },
        { "const": "completeness" },
        { "const": "runtime_behavior" },
        { "const": "test_sufficiency" },
        { "const": "regression_absence" },
        { "const": "semantic_importance" },
        { "const": "review_priority" },
        { "const": "change_impact" }
      ]
    }
  }
}
