{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://heimgewebe.local/schema/query-context-bundle.v1.schema.json",
  "title": "Query Context Bundle (query-context-bundle v1.0)",
  "description": "Portable context bundle representing query results with their evidence and expanded context.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "query",
    "hits"
  ],
  "properties": {
    "query": {
      "type": "string",
      "description": "The search query text."
    },
    "hits": {
      "type": "array",
      "description": "The contextualized hits.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "hit_identity",
          "file",
          "path",
          "range",
          "score",
          "resolved_code_snippet",
          "provenance_type",
          "bundle_source_references"
        ],
        "properties": {
          "hit_identity": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "range": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "explain": {
            "type": "object",
            "additionalProperties": true
          },
          "resolved_code_snippet": {
            "type": "string"
          },
          "surrounding_context": {
            "type": ["string", "null"]
          },
          "graph_context": {
            "type": ["object", "null"],
            "additionalProperties": true
          },
          "provenance_type": {
            "type": "string",
            "enum": ["explicit", "derived"]
          },
          "range_ref": {
            "type": "object",
            "additionalProperties": true
          },
          "derived_range_ref": {
            "type": "object",
            "additionalProperties": true
          },
          "bundle_source_references": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "epistemics": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "provenance_type",
              "bundle_origin",
              "resolver_status",
              "graph_status",
              "semantic_status",
              "federation_status",
              "uncertainty",
              "interpolation"
            ],
            "properties": {
              "provenance_type": {
                "type": "string"
              },
              "bundle_origin": {
                "type": "string"
              },
              "resolver_status": {
                "type": "string"
              },
              "graph_status": {
                "type": "string"
              },
              "semantic_status": {
                "type": "string"
              },
              "federation_status": {
                "type": "string"
              },
              "uncertainty": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "explicit_provenance",
                  "graph_used",
                  "semantic_supported"
                ],
                "properties": {
                  "explicit_provenance": { "type": "boolean" },
                  "graph_used": { "type": "boolean" },
                  "semantic_supported": { "type": "boolean" }
                }
              },
              "interpolation": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "used",
                  "reason"
                ],
                "properties": {
                  "used": { "type": "boolean" },
                  "reason": { "type": ["string", "null"] }
                }
              }
            }
          }
        }
      }
    }
  }
}
