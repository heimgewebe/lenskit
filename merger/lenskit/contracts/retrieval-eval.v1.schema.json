{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lenskit.merger/schemas/retrieval-eval.v1.json",
  "title": "Lenskit Retrieval Evaluation Report",
  "description": "Output schema for 'lenskit eval --emit json', containing metrics and query details.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "metrics": {
      "type": "object",
      "description": "Aggregate metrics for the evaluation run.",
      "additionalProperties": false,
      "properties": {
        "MRR": {
          "type": "number",
          "description": "Mean Reciprocal Rank for the overall evaluation run.",
          "minimum": 0,
          "maximum": 1
        },
        "baseline_MRR": {
          "type": "number",
          "description": "Baseline Mean Reciprocal Rank without semantic reranking.",
          "minimum": 0,
          "maximum": 1
        },
        "baseline_hits": {
          "type": "integer",
          "description": "Number of baseline hits without semantic reranking.",
          "minimum": 0
        },
        "semantic_MRR": {
          "type": "number",
          "description": "Semantic Mean Reciprocal Rank.",
          "minimum": 0,
          "maximum": 1
        },
        "semantic_hits": {
          "type": "integer",
          "description": "Number of semantic hits.",
          "minimum": 0
        },
        "delta_recall": {
          "type": "number",
          "description": "Difference in recall (semantic minus baseline)."
        },
        "delta_mrr": {
          "type": "number",
          "description": "Difference in MRR (semantic minus baseline)."
        },
        "total_queries": {
          "type": "integer",
          "description": "Total number of queries in the evaluation set.",
          "minimum": 0
        },
        "hits": {
          "type": "integer",
          "description": "Number of queries where at least one expected path was found in the top-k results.",
          "minimum": 0
        },
        "stale_flag": {
          "type": "boolean",
          "description": "True if the index was stale during evaluation."
        },
        "zero_hit_ratio": {
          "type": "number",
          "description": "Ratio of queries that returned 0 total hits (0.0 to 1.0).",
          "minimum": 0,
          "maximum": 1
        },
        "categories": {
          "type": "object",
          "description": "Metrics broken down by category.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "total_queries": {
                "type": "integer",
                "minimum": 0
              },
              "hits": {
                "type": "integer",
                "minimum": 0
              },
              "MRR": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "base_hits": {
                "type": "integer",
                "minimum": 0
              },
              "base_mrr_sum": {
                "type": "number",
                "minimum": 0
              },
              "sem_hits": {
                "type": "integer",
                "minimum": 0
              },
              "sem_mrr_sum": {
                "type": "number",
                "minimum": 0
              },
              "semantic_MRR": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "patternProperties": {
              "^recall@\\d+$": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "^semantic_recall@\\d+$": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              }
            },
            "required": ["total_queries"]
          }
        }
      },
      "patternProperties": {
        "^recall@\\d+$": {
          "type": "number",
          "description": "Recall at K, strictly represented as a percentage (0.0 to 100.0). Note: accept_criteria in queries JSON uses a ratio (0.0 to 1.0).",
          "minimum": 0,
          "maximum": 100
        },
        "^baseline_recall@\\d+$": {
          "type": "number",
          "description": "Baseline Recall at K without semantic reranking.",
          "minimum": 0,
          "maximum": 100
        },
        "^semantic_recall@\\d+$": {
          "type": "number",
          "description": "Semantic Recall at K.",
          "minimum": 0,
          "maximum": 100
        }
      },
      "required": [
        "total_queries",
        "hits",
        "stale_flag"
      ]
    },
    "details": {
      "type": "array",
      "description": "Detailed results for each query.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "query": {
            "type": "string",
            "description": "The query text."
          },
          "category": {
            "type": ["string", "null"],
            "description": "The category of the query."
          },
          "filters": {
            "type": "object",
            "description": "Filters applied to the query.",
            "additionalProperties": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "expected": {
            "type": "array",
            "description": "List of expected path substrings.",
            "items": {
              "type": "string"
            }
          },
          "is_relevant": {
            "type": "boolean",
            "description": "True if an expected path was found in the top results."
          },
          "hit_path": {
            "type": [
              "string",
              "null"
            ],
            "description": "The first matching path found, if any."
          },
          "found_count": {
            "type": "integer",
            "description": "Total number of results returned by the index for this query.",
            "minimum": 0
          },
          "top_results": {
            "type": "array",
            "description": "List of paths returned in the top-k results.",
            "items": {
              "type": "string"
            }
          },
          "error": {
            "type": [
              "string",
              "null"
            ],
            "description": "Error message if the query failed."
          },
          "why": {
            "type": "object",
            "description": "Machine-readable explainability block for the matched hit.",
            "additionalProperties": false,
            "required": [
              "matched_terms",
              "filter_pass",
              "rank_features"
            ],
            "properties": {
              "matched_terms": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "The input or translated terms used for execution."
              },
              "filter_pass": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "List of global filter keys applied to the query."
              },
              "rank_features": {
                "type": "object",
                "additionalProperties": true,
                "description": "Ranking features like bm25."
              },
              "diagnostics": {
                "type": "object",
                "additionalProperties": true,
                "description": "Optional diagnostics information."
              }
            }
          }
        },
        "required": [
          "query",
          "is_relevant",
          "found_count",
          "expected"
        ]
      }
    }
  },
  "required": [
    "metrics",
    "details"
  ]
}
