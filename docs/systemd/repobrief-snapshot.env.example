# Example: copy to ~/.config/repobrief/snapshots/lenskit.env
# The scheduler expands %h to the user home directory.

REPOBRIEF_REPO=%h/repos/lenskit
REPOBRIEF_OUT=%h/lenskit-out/repobrief/lenskit
REPOBRIEF_PROFILE=agent-portable

# Optional: archive, retrieval, or dual.
# REPOBRIEF_OUTPUT_MODE=dual

# Optional: location of the lenskit checkout that provides the RepoBrief CLI.
# REPOBRIEF_LENSKIT_ROOT=%h/repos/lenskit
